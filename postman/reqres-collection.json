          "name": "Create Record - Valid Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 201\", function (){\r",
                  "    pm.response.to.have.status(201);\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Response body contains 'data' object\", function (){\r",
                  "    pm.expect(response).to.have.property('data');\r",
                  "    pm.expect(response.data).to.be.an('object');\r",
                  "})\r",
                  "\r",
                  "pm.test(\"'data' object has 'id'\", function(){\r",
                  "    pm.expect(response.data).to.have.property(\"id\");\r",
                  "})\r",
                  "\r",
                  "pm.test(\"'id' is a UUID string\", function(){\r",
                  "    pm.expect(response.data.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i);\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Record has all submitted fields\", function(){\r",
                  "    pm.expect(response.data.data).to.have.property(\"name\");\r",
                  "    pm.expect(response.data.data).to.have.property(\"price\");\r",
                  "    pm.expect(response.data.data).to.have.property(\"category\");\r",
                  "    pm.expect(response.data.data).to.have.property(\"in_stock\");\r",
                  "})\r",
                  "\r",
                  "pm.environment.set(\"recordId\", response.data.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
